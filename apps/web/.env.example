VITE_API_URL=/api

# Server-side only (Vercel serverless at /api/vercel/status, or `vercel dev`).
# Create a token: Vercel dashboard → Account Settings → Tokens.
# Set the same variable in Vercel → Project → Environment Variables (Production / Preview).
# Never prefix with VITE_ — that would expose the token in the browser bundle.
# VERCEL_TOKEN=

# Optional: when running `npx vercel dev` from repo root, proxy /api to Vercel (often http://127.0.0.1:3000)
# so `npm run dev` can call serverless routes. Not used in production builds.
# DEV_PROXY_VERCEL=

# Google Locator Plus (Contact page). Keys are read from apps/web/.env via vite.config.ts.
# VITE_GOOGLE_MAPS_API_KEY takes precedence; GOOGLE_MAPS_API_KEY is merged as a fallback.
VITE_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

VITE_GOOGLE_MAPS_MAP_ID=906c3323e7d994d3623f143d
